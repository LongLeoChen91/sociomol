# Python byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
MANIFEST

# Environments
.env
.venv
env/
venv/

# Test / tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Generated outputs (produced when users run examples or predictions)
*_annotated.star
*_edges.csv

# Whitelist demo data in examples/ (these are committed intentionally)
!examples/**/*.star
!examples/**/*.csv
!examples/**/*.sh