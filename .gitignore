# Python byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
MANIFEST

# Environments
.env
.venv
env/
venv/

# Test / tool caches
.pytest_cache/
